<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Comments_Length</fullName>
    <active>false</active>
    <errorConditionFormula>LEN (Description) &gt; 999</errorConditionFormula>
    <errorDisplayField>Description</errorDisplayField>
    <errorMessage>The Account Comments field must be under 999 characters. Please edit and shorten and save.</errorMessage>
</ValidationRule>
