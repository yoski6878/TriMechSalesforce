<?xml version="1.0" encoding="UTF-8"?>
<LightningComponentBundle xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>59.0</apiVersion>
    <isExposed>true</isExposed>
    <masterLabel>CSV Data Exporter</masterLabel>
    <description>This component exports the collection variable data into a CSV file.</description>
    <targets>
        <target>lightning__FlowScreen</target>
    </targets>

    <targetConfigs>
        <targetConfig targets="lightning__FlowScreen">
            <property name="csvString" type="String" label="CSV String" description="CSV data to download" />
            <property name="filename" type="String" label="Filename" description="Name for the downloaded CSV file" />
        </targetConfig>
    </targetConfigs>
</LightningComponentBundle>